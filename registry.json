{
  "_about": "Mod registry — single source of truth for publish verification + audit. Consumed by the scheduled audit (release-actions/verify), which has NO local checkout of these repos and discovers tags + per-tag publish metadata via the GitHub API. The per-tag verify.yml reads each mod's own gradle.properties at the tag ref, so it does NOT depend on this file. JSON (not YAML) so the stdlib-only Python verifier can parse it with no deps. To add a mod: append one entry here + add the verify.yml call to that repo's release.yml (see ONBOARDING).",
  "defaults": {
    "platforms": ["fabric", "forge", "neoforge"],
    "tag_pattern": "^v?(?P<version>\\d+\\.\\d+\\.\\d+(?:-alpha\\.\\d+)?)-(?P<mc>.+)$"
  },
